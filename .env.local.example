# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Required for AI features (Amazon Bedrock) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here

# Optional: override model ids if your account uses inference-profile ids
# BEDROCK_MODEL_EXTRACT=anthropic.claude-3-5-haiku-20241022-v1:0
# BEDROCK_MODEL_CHAT=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Auth ---
# Used to sign session cookies. Set any long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Storage backend ---
# Leave unset for local dev -> uses a JSON file at .data/db.json (no AWS needed).
# Set STORE=dynamo (and the table below) to use DynamoDB in production.
# STORE=dynamo
# DDB_TABLE=CampusFlow
